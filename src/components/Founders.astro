---
import { Image } from 'astro:assets';

interface Founder {
  name: string;
  role: string;
  image: string;
}

interface Props {
  founders?: Founder[];
  title?: string;
}

const { 
  founders = [
    {
      name: "Frog",
      role: "Founder & CEO",
      image: "https://fonts.gstatic.com/s/e/notoemoji/latest/1f438/512.gif",
    },
    {
      name: "Rocket",
      role: "Founder & CTO",
      image: "https://fonts.gstatic.com/s/e/notoemoji/latest/1f680/512.gif",
    },
  ],
  title = "Our Founders" 
} = Astro.props;
---

<section class="py-12 px-4 max-w-1/2">
  <div class="container mx-auto">
    <h2 class="text-3xl font-bold text-center mb-12">{title}</h2>

    <div class="flex flex-wrap gap-8">
      {founders.map((founder) => (
        <div class="flex flex-col items-center group">
          <div class="relative mb-4 overflow-hidden rounded-full w-40 h-40 border-2 border-gray-100 shadow-md transition-transform duration-300 group-hover:scale-105">
            <img
            src={founder.image || "/assets/founders/frog.svg"}
              alt={`Photo of ${founder.name}`}
              class="object-cover w-full h-full"
            />
          </div>
          <h3 class="font-semibold text-lg text-center">{founder.name}</h3>
          <p class="text-gray-600 text-center">{founder.role}</p>
        </div>
      ))}
    </div>
  </div>
</section>

