---
import '../styles/global.css';
// Component Imports

import { ScrollArea } from "@/components/ui/scroll-area";
import Founders from "@/components/Founders.astro";
import BentoItem from "@/components/BentoItem.astro";

// Full Astro Component Syntax:
// https://docs.astro.build/basics/astro-components/
const tags = Array.from({ length: 50 }).map(
  (_, i, a) => `v1.2.0-beta.${a.length - i}`
)
const classes = [
  "Math 7",
  "Math 8",
  "Math 9",
  "Math 10",
  "Math 10 IB",
  "Math 20 IB",
  "Science 10 IB",
  "Science 20 IB",
  "Biology 20 IB",
  "Chemistry 20",
  "Compositional Writing 10",
  "Reading Comprehension 10",
  "Web Design and Development",
  "Systems Engineering and Programming",
]
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Glass Frog</title>
	</head>

	<body class="bg-zinc-200">
    <div class="h-[calc(80vh)] flex items-center justify-center flex-col">
      <div class="flex flex-col items-center justify-center gap-10 bg-gradient-to-b from-zinc-700 to-zinc-800 text-transparent bg-clip-text">
        <h1 class="text-6xl font-bold">Leap with <b>Clarity</b></h1>
        <h1 class="text-6xl font-bold">Land with <b>Confidence</b></h1>
      </div>
      <p class="max-w-3xl mt-10 font-semibold text-center"><i>A teen-led community empowering students to conquer the high school transition through peer mentorship, skill-building courses, and hands-on competitions.</i></p>
      <p class="mt-4">Middle school to high school feels overwhelming. <b>We make it simpler.</b></p>
    </div>
    <div class="flex flex-col justify-center max-w-5xl mx-auto gap-4">
      <div class="flex w-full gap-4">
        <!-- <div class={`flex-1/2 p-4 border border-dashed border-zinc-700 rounded-xl bg-zinc-300 shadow-lg`}> -->
        <BentoItem classes="flex-2/5">
          <h2 class="text-xl font-bold mb-2">About Grass Frog Academy</h2>
          <p>At Grass Frog Academy, we believe the leap from middle school to high school is one of the most difficult jumps in a student’s life.<br> Our name embodies this philosophy: <i>Glass</i> symbolizes clarity, and a window into the future, while <i>Frog</i> represents the academic leap all students make at the end of middle school.</p>
        </BentoItem>
        <BentoItem classes="flex-2/5">
          <h2 class="text-xl font-bold mb-2">Our Mission</h2>
          <p>We prepare middle school students to thrive in high school and beyond through online classes, and in person hackathons. With a focus on the International Baccalaureate (IB) curriculum, we equip students with the tools to navigate complex challenges, think critically, and embrace their potential.</p>
        </BentoItem>
      </div>
      <div class="flex w-full gap-4">
        <BentoItem classes="flex-1/3">
          <h2 class="text-xl font-bold mb-2">What we Teach</h2>
          <ScrollArea className="w-full h-40" client:load>
            <ul class="list-disc pl-4">
              {classes.map((clas) => (
                // if i get rid of this div it wont work
                <li class="mb-2">{clas}</li>
              ))}
            </ul>
          </ScrollArea>
        </BentoItem>
        <BentoItem classes="flex-1/2">
          <h2 class="text-xl font-bold mb-2">What we do</h2>
          <ul class="list-disc pl-4">
            <li><b>Summer Online Courses</b>: Tailored classes in IB Science, Math, writing, plus advanced topics like Physics, Biology, and Computer Science.</li>
            <li><b>In-person events</b>: Competitions and hackathons that help build abilities through interactive and physical activities</li>
            <li><b>Provide Future Readiness</b>: We provide experience from current IB high school students and help students get used to the high school workflow</li>
          </ul>
        </BentoItem>
      </div>
    </div>
    <Founders />
	</body>
</html>
