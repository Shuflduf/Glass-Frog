---
import "../styles/global.css";

import NavBar from "@/components/NavBar.astro";
import Footer from "@/components/Footer.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Glass Frog</title>
  </head>

  <body class="bg-zinc-200 w-full">
    <NavBar />
    <div class="h-24" />
    <section class="py-12 px-4 mx-auto flex items-center flex-col max-w-5xl">
      <h1 class="text-5xl font-bold text-center mb-4">Events</h1>
      <h2 class="text-xl font-semibold mb-8"><i>All events hosted by Glass Frog Academy are free of charge and open to all students</i></h2>
      <p class="mb-8 text-center">Glass Frog Academy is hosting a hackathon and a math competition at the end of the 2025 Summer Course. <i>(Note that you do not have to participate in the Summer Course to attend any events.)</i> Please fill out this interest form if you wish to attend any of these events. More information will be provided later.</p>
      <iframe src="https://docs.google.com/forms/d/e/1FAIpQLSfN1nHc2AWuhgXPxfpm6KuUDXZQoEmFyMwmXDNUTvLROaf8ag/viewform?embedded=true" width="700" height="1260">Loading…</iframe>
    </section>
    <Footer />
  </body>
</html>
