---
import BentoItem from "../../components/BentoItem.astro";
import { ScrollArea } from "../../components/ui/scroll-area";

const classes = ["Math", "Science", "Humanities", "Computer Science"];
---

<div class="flex flex-col justify-center max-w-5xl mx-auto gap-6 px-4">
  <div class="flex w-full gap-6 flex-wrap">
    <BentoItem classes="flex-2/5">
      <h2 class="text-xl font-bold mb-2">About Grass Frog Academy</h2>
      <p>
        At Grass Frog Academy, we believe the leap from middle school to high
        school is one of the most difficult jumps in a student’s life.<br /> Our
        name embodies this philosophy: <i>Glass</i> symbolizes clarity, and a window
        into the future, while <i>Frog</i> represents the academic leap all students
        make at the end of middle school.
      </p>
    </BentoItem>
    <BentoItem classes="flex-2/5">
      <h2 class="text-xl font-bold mb-2">Our Mission</h2>
      <p>
        We prepare middle school students to thrive in high school and beyond
        through online classes, and in person hackathons. With a focus on the
        International Baccalaureate (IB) curriculum, we equip students with the
        tools to navigate complex challenges, think critically, and embrace
        their potential.
      </p>
    </BentoItem>
  </div>
  <div class="flex w-full gap-6 flex-wrap">
    <BentoItem classes="flex-1/3">
      <!--
        change this to show the main courses, with a 
        view more button leading to the classes page
      -->
      <h2 class="text-xl font-bold mb-2">What we Teach</h2>
      <!-- <ScrollArea className="w-full h-40" client:load> -->
      <!--   <ul class="list-disc pl-4"> -->
      <!--     {classes.map((clas) => <li class="mb-2">{clas}</li>)} -->
      <!--   </ul> -->
      <!-- </ScrollArea> -->
      <ul class="list-disc pl-4">
        {classes.map((clas) => <li>{clas}</li>)}
        <li>
          <button class="text-blue-500 background-zinc-800">
            <a href="/classes" class="text-blue-500 hover:underline">
              View More Info
            </a>
          </button>
        </li>
      </ul>
    </BentoItem>
    <BentoItem classes="flex-1/2">
      <h2 class="text-xl font-bold mb-2">What we do</h2>
      <ul class="list-disc pl-4">
        <li>
          <b>Summer Online Courses</b>: Tailored classes in IB Science, Math,
          writing, plus advanced topics like Physics, Biology, and Computer
          Science.
        </li>
        <li>
          <b>In-person events</b>: Competitions and hackathons that help build
          abilities through interactive and physical activities
        </li>
        <li>
          <b>Provide Future Readiness</b>: We provide experience from current IB
          high school students and help students get used to the high school
          workflow
        </li>
      </ul>
    </BentoItem>
  </div>
</div>
