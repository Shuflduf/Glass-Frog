---
import { team } from "@/components/team.ts";
import type { Member } from "@/components/team.ts";
---

<div class="h-24"></div>
<section class="py-12 px-4 max-w-3xl mx-auto">
  <h2 class="text-5xl font-bold text-center mb-12">Our Team</h2>
  <div class="flex flex-col gap-4">
    {
      (team as Member[]).map((member) => (
        <div class="flex">
          <div class="overflow-hidden rounded-full w-40 h-40 border-2 border-gray-100 shadow-md transition-transform duration-300 hover:scale-105">
            <img
              src={member.image || "/assets/founders/frog.svg"}
              alt={member.name}
              class="object-cover w-full h-full"
            />
          </div>
          <div class="ml-4 flex flex-col justify-center w-60">
            <h3 class="font-semibold text-lg text-center">{member.name}</h3>
            <ul class="text-gray-600 text-center">
              {member.roles.map((role) => (
                <li>{role}</li>
              ))}
            </ul>
          </div>
          {member.bio && (
            <div class="flex items-center">
              <div class="p-4 border-l-zinc-400 border-2 h-min">
                <p class="w-80 italic" set:html={member.bio} />
              </div>
            </div>
          )}
        </div>
      ))
    }
  </div>
</section>
